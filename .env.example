# Copy this to .env and fill in your real keys
# NEVER commit .env

COHERE_API_KEY=your_cohere_api_key_here

# TrueLayer sandbox (https://console.truelayer.com)
# Step 1: create an app at console.truelayer.com → copy client_id and client_secret
# Step 2: complete the OAuth2 consent flow once (see README) to get access + refresh tokens
# Step 3: paste both below. The adapter auto-refreshes access_token using refresh_token.
#         Refresh token lasts ~30 days; repeat step 2 after expiry.
TRUELAYER_CLIENT_ID=your_truelayer_client_id_here
TRUELAYER_CLIENT_SECRET=your_truelayer_client_secret_here
TRUELAYER_REFRESH_TOKEN=your_refresh_token_here
TRUELAYER_ACCESS_TOKEN=your_access_token_here   # optional — auto-refreshed if missing
